# Discord webhook for Tier 1 alerts
# Create one at: Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Reddit API credentials (free — register at https://www.reddit.com/prefs/apps)
# Create a "script" type app
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=watchtower:v1.0 (by /u/your_reddit_username)
